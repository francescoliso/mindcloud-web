generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (unpooled) connection for migrations — Neon's pooled URL can
  // stall on migration locks. Falls back to DATABASE_URL locally.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id             String          @id @default(uuid()) @db.Uuid
  email          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  onboardedAt    DateTime?
  journalEntries JournalEntry[]
  gratitudeItems GratitudeItem[]
  weeklyReports  WeeklyReport[]
  moodEntries    MoodEntry[]
  lifeWheel      LifeWheel?
}

// One row per user. goals = { work: 8, love: 7, … }
// current = { work: { score: 5, comment: "…" }, … }
model LifeWheel {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals     Json
  current   Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum WaitlistStatus {
  PENDING
  INVITED
  REGISTERED
}

model WaitlistEntry {
  id             String         @id @default(uuid()) @db.Uuid
  email          String         @unique
  status         WaitlistStatus @default(PENDING)
  inviteToken    String?        @unique
  invitedAt      DateTime?
  tokenExpiresAt DateTime?
  createdAt      DateTime       @default(now())
}

// Churn tracking. Holds no personal data — just enough to count users who
// deleted their account and how long they stayed.
model AccountDeletion {
  id               String   @id @default(uuid()) @db.Uuid
  accountCreatedAt DateTime
  wasOnboarded     Boolean
  deletedAt        DateTime @default(now())
}

// Fixed-window rate limiting (Postgres-backed, no external store).
model RateLimit {
  key       String   @id
  count     Int      @default(0)
  windowEnd DateTime
}

model JournalEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  // Plaintext labels (not encrypted) so entries stay filterable in SQL.
  tags      String[] @default([])
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model GratitudeItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  position  Int // 1, 2, or 3
  entryDate DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, entryDate, position])
}

model MoodEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int // 1 (struggling) … 5 (great)
  entryDate DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, entryDate])
}

model WeeklyReport {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  weekStart DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, weekStart])
}
